<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lemongo97.iptv.iptvmanager.mapper.ChannelMapper">

    <resultMap id="ChannelResultMap" type="com.lemongo97.iptv.iptvmanager.entity.Channel">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="logo" column="logo"/>
        <result property="url" column="url"/>
        <result property="providerId" column="provider_id"/>
        <result property="groupId" column="group_id"/>
        <result property="epgSourceId" column="epg_source_id"/>
        <result property="status" column="status"/>
        <result property="country" column="country"/>
        <result property="language" column="language"/>
        <result property="score" column="score"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <association property="channelGroup" javaType="com.lemongo97.iptv.iptvmanager.entity.ChannelGroup"
                     columnPrefix="group_">
            <id property="id" column="id"/>
            <result property="name" column="name"/>
            <result property="sortOrder" column="sort_order"/>
            <result property="description" column="description"/>
            <result property="createdAt" column="created_at"/>
            <result property="updatedAt" column="updated_at"/>
            <result property="deleted" column="deleted"/>
        </association>
        <association property="provider" javaType="com.lemongo97.iptv.iptvmanager.entity.M3U8Provider"
                     columnPrefix="provider_">
            <id property="id" column="id"/>
            <result property="name" column="name"/>
            <result property="type" column="type"/>
            <result property="url" column="url"/>
            <result property="filePath" column="file_path"/>
            <result property="headers" column="headers"
                    typeHandler="org.apache.ibatis.type.UnknownTypeHandler"/>
            <result property="refreshRate" column="refresh_rate"/>
            <result property="enabled" column="enabled"/>
            <result property="description" column="description"/>
            <result property="createdAt" column="created_at"/>
            <result property="updatedAt" column="updated_at"/>
            <result property="deleted" column="deleted"/>
        </association>
    </resultMap>
    <update id="truncate">
        UPDATE channels
        SET deleted = 1
    </update>

    <select id="findAll" resultMap="ChannelResultMap">
        SELECT id,
               name,
               logo,
               url,
               group_id,
               epg_source_id,
               status,
               country,
               language,
               score,
               created_at,
               updated_at
        FROM channels
        WHERE deleted = 0
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="findById" resultMap="ChannelResultMap">
        SELECT id,
               name,
               logo,
               url,
               group_id,
               epg_source_id,
               status,
               country,
               language,
               score,
               created_at,
               updated_at
        FROM channels
        WHERE id = #{id}
          AND deleted = 0
    </select>

    <select id="findByGroup" resultMap="ChannelResultMap" resultType="com.lemongo97.iptv.iptvmanager.entity.Channel">
        SELECT c.id,
               c.name,
               c.logo,
               c.url,
               c.number,
               c.channel_id,
               c.enabled,
               c.provider_id,
               c.group_id,
               c.epg_source_id,
               c.sort_order,
               c.description,
               c.created_at,
               c.updated_at,
               c.deleted
        FROM channels c
                 INNER JOIN channel_groups g ON c.group_id = g.id
        WHERE g.name = #{group}
          AND c.deleted = 0
          AND g.deleted = 0
        ORDER BY c.sort_order ASC, c.id ASC
    </select>

    <select id="findByCondition" resultMap="ChannelResultMap">
        SELECT
        c.id, c.name, c.logo, c.url, c.group_id, c.provider_id, c.epg_source_id, c.status, c.country, c.language,
        c.score, c.created_at, c.updated_at,
        cg.name as group_name, cg.description as group_description,
        p.name as provider_name
        FROM
        channels c
        LEFT JOIN channel_groups cg
        on c.group_id = cg.id
        LEFT JOIN m3u8_providers p
        on c.provider_id = p.id

        <where>
            c.deleted = 0 AND cg.deleted = 0 AND p.deleted = 0
            <if test="query.name != null">
                AND c.name like concat('%', #{query.name}, '%')
            </if>
            <if test="query.providerId != null">
                AND c.provider_id = #{query.providerId}
            </if>
            <if test="query.groupId != null">
                AND c.group_id = #{query.groupId}
            </if>
            <if test="@org.apache.commons.lang3.StringUtils@isNotBlank(query.orderBy) and query.asc != null">
                <choose>
                    <when test="query.orderBy == 'name'">
                        ORDER BY c.name
                        <choose>
                            <when test="query.asc">
                                ASC
                            </when>
                            <otherwise>DESC</otherwise>
                        </choose>
                    </when>
                </choose>
            </if>
        </where>

    </select>

    <insert id="insert">
        INSERT INTO channels (name, logo, url, provider_id, group_id, epg_source_id,
        status, country, language, score, created_at, updated_at, deleted)
        VALUES
        <foreach collection="channels" item="item" separator=",">
            (#{item.name}, #{item.logo}, #{item.url}, #{item.providerId}, #{item.groupId}, #{item.epgSourceId},
            #{item.status},
            #{item.country}, #{item.language},
            #{item.score}, #{item.createdAt}, #{item.updatedAt}, 0)
        </foreach>
    </insert>

</mapper>
