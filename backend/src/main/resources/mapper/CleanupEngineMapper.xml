<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lemongo97.iptv.iptvmanager.mapper.CleanupEngineMapper">

    <resultMap id="CleanupEngineResultMap" type="com.lemongo97.iptv.iptvmanager.entity.CleanupEngine">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="engine" column="engine"/>
        <result property="ruleType" column="rule_type"/>
        <result property="params" column="params"/>
        <result property="description" column="description"/>
        <result property="fullClassName" column="full_class_name"/>
    </resultMap>

    <select id="findAll" resultMap="CleanupEngineResultMap">
        select id, name, engine, rule_type, params, description, full_class_name from cleanup_engine
    </select>

</mapper>
